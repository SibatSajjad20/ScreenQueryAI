{
  "manifest_version": 3,
  "name": "ScreenQuery AI",
  "version": "1.0.0",
  "description": "Ask AI questions about your screen.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "options_page": "settings.html",
  "permissions": ["activeTab", "storage", "tabs"],
  "icons": {
    "128": "icon.png"
  }
}
